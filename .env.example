# EN: Copy this file to .env and adjust local credentials before running the project.
#     Use placeholders here only; real contacts and passwords belong to the private .env.
# RU: Скопируйте файл в .env и настройте локальные данные перед запуском проекта.
#     Здесь только плейсхолдеры; реальные контакты и пароли — только в приватном .env.

APP_NAME=QazJumys
APP_ENV=local
APP_DEBUG=false
APP_URL=http://127.0.0.1:8014

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qazjumys_portal
DB_USERNAME=root
DB_PASSWORD=

SESSION_NAME=qazjumys_session
MAIL_TO=owner@example.com
MAIL_ENABLED=false
MAIL_FROM=no-reply@qazjumys.local
WHATSAPP_DEFAULT=
UPLOAD_MAX_BYTES=5242880
